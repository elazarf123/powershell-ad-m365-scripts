# ─── PowerShell Artifacts ─────────────────────────────────────────────────────
*.ps1xml
*.psd1.bak
*.psm1.bak

# ─── Output / Log Files ───────────────────────────────────────────────────────
# Generated by scripts at runtime – never commit tenant data or reports
*.csv
*.json
*.log
*.zip
*.html
Logs/
logs/
Reports/
reports/
Output/
output/

# ─── Credential / Secret Files ────────────────────────────────────────────────
# See SECURITY.md – secrets must NEVER be stored in this repo
*.pfx
*.cer
*.key
*.pem
*.creds
.env
.env.*
secrets.ps1
credentials.ps1
config.local.ps1

# ─── PSScriptAnalyzer / PSake / Pester ───────────────────────────────────────
TestResults/
testResults.xml
*.NUnitXml
coverage.xml
.pester/

# ─── VS Code ──────────────────────────────────────────────────────────────────
.vscode/
!.vscode/settings.json
!.vscode/extensions.json

# ─── Visual Studio / Rider ────────────────────────────────────────────────────
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser

# ─── OS Artifacts ─────────────────────────────────────────────────────────────
# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~

# ─── Temporary & Editor Swap Files ───────────────────────────────────────────
*.tmp
*.bak
*.swp
*.swo
[._]*.s[a-v][a-z]
[._]*.sw[a-p]

# ─── NuGet / Package Management ───────────────────────────────────────────────
packages/
*.nupkg

# ─── Examples (keep sample files; ignore generated tenant-specific outputs) ───
# Allow the sanitized sample files checked in under examples/
!examples/*.csv
!examples/*.json

# ─── Node (only if tooling such as markdownlint is used locally) ──────────────
node_modules/
